# Copy to .env and fill in. .env is gitignored. Anything already set in the
# real environment takes precedence over .env.

# Jira context for the overview page (optional). If unset, the overview shows a
# setup banner instead of the linked story/epic.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_TOKEN=your-jira-api-token

# Epic-Link custom field id (optional; default: customfield_10008)
# JIRA_EPIC_FIELD=customfield_10008

# Default PR for `pnpm dev` (optional): owner/repo#N
# PR_REF=owner/repo#123

# Where review state is persisted (optional; default: ~/.pr-review)
# PR_REVIEW_STATE_DIR=/path/to/state
