{
  "name": "pr-review",
  "version": "0.0.1",
  "description": "Standalone CLI: serve a browser UI to walk a GitHub PR hunk by hunk.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.18"
  },
  "bin": {
    "pr-review": "build/cli.js"
  },
  "scripts": {
    "cli": "ts-node src/cli.ts",
    "api": "ts-node src/cli.ts --api-only",
    "dev:web": "vite web",
    "dev": "concurrently -k -n api,web -c blue,magenta \"pnpm api\" \"pnpm dev:web\"",
    "build": "tsc -p tsconfig.json && pnpm build:web",
    "build:web": "vite build web",
    "start": "node build/cli.js",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "highlight.js": "^11.11.1",
    "motion": "^12.40.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/vite": "^4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "globals": "^16",
    "jest": "^29.7.0",
    "prettier": "^3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^6"
  }
}
