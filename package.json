{
  "name": "assisted-review",
  "version": "1.11.0",
  "description": "Standalone CLI: serve a browser UI to walk a GitHub PR hunk by hunk.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moui72/assisted-review.git"
  },
  "engines": {
    "node": ">=20.18"
  },
  "bin": {
    "assisted-review": "build/cli.js"
  },
  "files": [
    "build",
    "dist"
  ],
  "scripts": {
    "cli": "tsx src/cli.ts",
    "api": "tsx src/cli.ts --api-only",
    "dev:web": "vite web",
    "dev": "concurrently -k -n api,web -c blue,magenta \"pnpm api\" \"pnpm dev:web\"",
    "build": "tsc -p tsconfig.json && vite build web",
    "build:web": "vite build web",
    "prepack": "tsc -p tsconfig.json && vite build web",
    "start": "node build/cli.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "parse-diff": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "globals": "^16",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "motion": "^12.40.0",
    "prettier": "^3",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^4.1.9"
  }
}
